[MASTER]
jobs=1

[MESSAGES CONTROL]
disable=
    missing-module-docstring,
    missing-class-docstring,
    missing-function-docstring,
    too-many-arguments,
    too-many-positional-arguments,
    too-many-locals,
    too-few-public-methods,
    too-many-instance-attributes,
    too-many-branches,
    too-many-statements,
    too-many-return-statements,
    import-outside-toplevel,
    global-statement,
    duplicate-code,
    fixme,
    broad-exception-caught,
    import-error

[FORMAT]
max-line-length=80
indent-string='    '

[DESIGN]
max-args=10
max-locals=20
max-attributes=12

[BASIC]
good-names=i,j,k,x,y,n,df,ax,e,f,v,t,r

[SIMILARITIES]
min-similarity-lines=10

[TYPECHECK]
ignored-modules=numpy,pandas,matplotlib,cv2,mediapipe,streamlit

[REPORTS]
output-format=text
score=yes
